# --------------------- PRECOMPUTE: HP maps (14x14) -------------------
def highpass_mag_224(gray_224, r_hp):
    # FFT high-pass magnitude in [0,1]
    fshift = np.fft.fftshift(np.fft.fft2(gray_224))
    h, w = gray_224.shape
    cy, cx = h//2, w//2
    Y, X = np.ogrid[:h, :w]
    mask = ((Y - cy)**2 + (X - cx)**2) > (r_hp**2)
    recon = np.fft.ifft2(np.fft.ifftshift(fshift * mask))
    mag = np.abs(recon)
    mag -= mag.min()
    mag /= (mag.max() + HP_EPS)
    return mag  # float64 [0..1]

def hp_to_patch_map_14x14(hp224):
    # Average over each 16x16 patch region to align with ViT patching
    # reshape (224,224) -> (14,16,14,16) and mean over (1,3) -> (14,14)
    H, W = hp224.shape
    assert H == 224 and W == 224, "HP map must be 224x224"
    hp = hp224.reshape(14,16,14,16).mean(axis=(1,3))  # (14,14)
    return hp

def list_image_paths(root):
    root = Path(root)
    exts = (".jpg", ".jpeg", ".png", ".bmp", ".tif", ".tiff", ".webp")
    return sorted([p for p in root.rglob("*") if p.suffix.lower() in exts])

def ensure_hp_maps_for_dataset(data_root):
    imgs = list_image_paths(data_root)
    if not imgs:
        raise RuntimeError(f"No images found under {data_root}")
    t0 = time.time()
    wrote = 0
    for i, p in enumerate(imgs, 1):
        outp = Path(HP_DIR) / f"{p.stem}.pt"
        if outp.exists():  # skip if already computed
            continue
        gray = cv2.imread(str(p), cv2.IMREAD_GRAYSCALE)
        if gray is None:
            print(f"[HP][WARN] Could not read {p}; skipping.")
            continue
        gray = cv2.resize(gray, (224,224), interpolation=cv2.INTER_AREA)
        hp224 = highpass_mag_224(gray, R_HP)
        hp14  = hp_to_patch_map_14x14(hp224)     # (14,14), 0..1
        hp196 = torch.from_numpy(hp14.astype(np.float32)).reshape(-1)  # (196,)
        torch.save(hp196, outp)
        wrote += 1
        if i % 200 == 0 or i == len(imgs):
            print(f"[HP] {i}/{len(imgs)} processed | wrote={wrote} | {gpu_mem()}")
    print(f"[HP] Done in {time.time()-t0:.1f}s | new maps: {wrote} | dir={HP_DIR}")

